# Exclude environment variables and virtual environments
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Exclude node_modules
node_modules/
dist/

# Exclude logs
*.log
renderer.log
server_crash.log
server_debug.log
voices_output.txt
voices_output_utf8.txt

# Exclude OS-specific files
.DS_Store
Thumbs.db

# Exclude VS Code settings
.vscode/

# Exclude config with API keys — use config.example.json as template
config.json

# Exclude temp debug files
temp_*.txt
last_err.txt
server_debug_ascii.txt
server_debug_utf8.log

# Exclude local databases and caches
.chroma_db/
.claude/
lumina/
package-lock.json
